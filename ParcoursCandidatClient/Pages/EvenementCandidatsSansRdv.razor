@page "/evenements/{EvenementId}/candidats-sans-rdv"
@inject EvenementService EvenementService
@inject ICandidatsSansRdvService CandidatsSansRdvService

<PageTitle>@(_evenement?.Titre ?? "Événement") — Candidats sans RDV</PageTitle>

<div class="csr-page">

    <header class="csr-header">
        <a class="csr-header-back"
           href="/evenements/@EvenementId/tableau-de-bord"
           aria-label="Retour au tableau de bord">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </a>
        <h1 class="csr-header-titre">Candidats sans RDV</h1>
    </header>

    @if (_chargement)
    {
        <div class="csr-chargement" role="status" aria-label="Chargement en cours">
            <p>Chargement…</p>
        </div>
    }
    else if (_erreur is not null)
    {
        <div class="csr-erreur" role="alert">
            <p class="csr-erreur-message">Impossible de charger les candidats sans RDV.</p>
            <button class="csr-erreur-reessayer" @onclick="ChargerCandidatsSansRdv">Réessayer</button>
        </div>
    }
    else if (_candidatsSansRdv is not null && _candidatsSansRdv.Candidats.Count > 0)
    {
        <div class="csr-contenu">
            <div class="csr-liste" role="list">
                @foreach (var candidat in _candidatsSansRdv.Candidats)
                {
                    <div class="csr-candidat-carte" role="listitem">
                        <div class="csr-candidat-info">
                            <span class="csr-candidat-nom">@candidat.Nom.ToUpper() @candidat.Prenom.ToUpper()</span>
                        </div>
                        <a class="csr-candidat-appel"
                           href="tel:@candidat.Telephone"
                           aria-label="Appeler @candidat.Prenom @candidat.Nom">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                 fill="currentColor" aria-hidden="true">
                                <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
                            </svg>
                        </a>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="csr-vide" role="status">
            <p class="csr-vide-message">Aucun candidat sans RDV.</p>
        </div>
    }

</div>

@code {
    [Parameter] public string EvenementId { get; set; } = "";

    private Models.Evenement? _evenement;
    private Models.CandidatsSansRdv? _candidatsSansRdv;
    private bool _chargement = true;
    private string? _erreur;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ChargerEvenement(), ChargerCandidatsSansRdv());
    }

    private async Task ChargerEvenement()
    {
        try
        {
            _evenement = await EvenementService.GetEvenementByIdAsync(EvenementId);
        }
        catch
        {
            _evenement = null;
        }
    }

    private async Task ChargerCandidatsSansRdv()
    {
        _chargement = true;
        _erreur = null;
        try
        {
            _candidatsSansRdv = await CandidatsSansRdvService.GetCandidatsSansRdvAsync(EvenementId);
        }
        catch
        {
            _candidatsSansRdv = null;
            _erreur = "Impossible de charger les candidats sans RDV.";
        }
        finally
        {
            _chargement = false;
        }
    }
}
