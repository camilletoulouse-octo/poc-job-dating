@* === Bouton d'installation PWA =====================================
   Affiche un bouton "Installer l'application" uniquement lorsque le
   navigateur déclenche l'événement beforeinstallprompt.
   Le bouton est masqué si l'application est déjà installée ou si le
   navigateur ne supporte pas l'installation PWA.
   =================================================================== *@
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_installPromptDisponible)
{
    <button type="button"
            class="pwa-install-btn"
            aria-label="Installer l'application"
            title="Installer l'application"
            @onclick="InstallApp">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
    </button>
}

@code {
    private bool _installPromptDisponible = false;
    private DotNetObjectReference<PwaInstallButton>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("pwa.initInstallPrompt", _dotNetRef);

        _installPromptDisponible = await JS.InvokeAsync<bool>("pwa.isInstallPromptAvailable");
        StateHasChanged();
    }

    [JSInvokable]
    public void OnInstallPromptAvailable()
    {
        _installPromptDisponible = true;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnAppInstalled()
    {
        _installPromptDisponible = false;
        StateHasChanged();
    }

    private async Task InstallApp()
    {
        await JS.InvokeAsync<bool>("pwa.showInstallPrompt");
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await ValueTask.CompletedTask;
    }
}
