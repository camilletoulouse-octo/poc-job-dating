@* === Bottom navigation =========================================
   Barre de navigation principale à 3 entrées :
   - Scanner                (actif — navigue vers le scanner du premier événement)
   - Mes événements du jour (actif)
   - Rechercher un inscrit  (désactivé)
   ================================================================ *@
@inject NavigationManager Navigation

<nav class="me-bottom-nav" aria-label="Navigation principale">
    <button type="button" class="me-bottom-item" @onclick="NaviguerVersScanner">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
            <line x1="14" y1="14" x2="14" y2="17"></line>
            <line x1="17" y1="14" x2="21" y2="14"></line>
            <line x1="14" y1="20" x2="17" y2="20"></line>
            <line x1="20" y1="17" x2="20" y2="21"></line>
        </svg>
        <span>Scanner</span>
    </button>
    <button type="button" class="me-bottom-item me-bottom-item--active" aria-current="page">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span>Mes événements du jour</span>
    </button>
    <button type="button" class="me-bottom-item" disabled>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span>Rechercher un inscrit</span>
    </button>
</nav>

@code {
    // Pour le PoC, le scanner navigue vers le premier événement en dur.
    // L'EvenementId sera alimenté dynamiquement dans une prochaine US.
    private const string EvenementParDefautId = "evt-001";

    private void NaviguerVersScanner()
    {
        Navigation.NavigateTo($"/evenements/{EvenementParDefautId}/scanner");
    }
}

